# Copy this file to `.devcontainer/.env` and fill in any secrets you want the
# dev container to load. `start.sh` passes this file to `docker run --env-file`.
#
# The Anthropic API key for Claude Code inside the container (optional).
ANTHROPIC_API_KEY=

# Add any other environment variables your workflow needs below, e.g.:
# GITHUB_TOKEN=
# NPM_TOKEN=
