{
  "name": "@sofa-buffers/corelib",
  "version": "0.8.0",
  "description": "Streaming, dependency-free TypeScript implementation of the SofaBuffers binary serialization format — usable from Node.js, browsers, Electron, and classic <script>.",
  "keywords": [
    "sofabuffers",
    "serialization",
    "deserialization",
    "binary",
    "streaming",
    "varint",
    "tlv",
    "protocol",
    "encoding"
  ],
  "license": "MIT",
  "author": "SofaBuffers",
  "homepage": "https://github.com/sofa-buffers/corelib-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sofa-buffers/corelib-ts.git"
  },
  "bugs": {
    "url": "https://github.com/sofa-buffers/corelib-ts/issues"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node test/smoke.mjs && node test/smoke.cjs && node test/smoke-browser.mjs",
    "coverage": "vitest run --coverage",
    "bench": "tsx bench/bench.ts",
    "perf": "tsx bench/perf.ts",
    "bench:callgrind": "bash bench/run_callgrind.sh",
    "docs": "typedoc",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typedoc": "^0.28.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  }
}
