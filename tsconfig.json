{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "resolveJsonModule": true,
    // TS 6's dts build (rollup-plugin-dts) no longer auto-includes @types/node,
    // so the optional native loader's `process`/`node:module` refs need it named.
    "types": ["node"],
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    // tsup's dts build (rollup-plugin-dts) injects the now-deprecated `baseUrl`;
    // required until TS 7 to keep the declaration build from erroring (TS5101).
    "ignoreDeprecations": "6.0",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "test", "bench"]
}
